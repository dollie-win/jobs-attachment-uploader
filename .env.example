# Copy these into your Vercel project's Environment Variables (Settings -> Environment Variables).
# Do NOT commit a real .env with secrets.

# Required: Airtable personal access token.
# Create at https://airtable.com/create/tokens with scope: data.records:write
# and access to the Jobs base (appMMGRranZOTCyiX).
AIRTABLE_PAT=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: defaults to appMMGRranZOTCyiX if omitted.
AIRTABLE_BASE_ID=appMMGRranZOTCyiX

# Optional: if set, the extension must send the same value in header x-upload-secret.
# Note: this value lives in client-side extension code, so treat it as light
# abuse-prevention, not true authentication.
UPLOAD_SECRET=

# Optional: lock CORS to your Airtable extension origin instead of "*".
# Airtable extensions are served from https://*.airtableblocks.com
ALLOWED_ORIGIN=*
